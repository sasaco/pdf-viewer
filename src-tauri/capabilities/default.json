{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "$DOCUMENT/**/*.pdf"
        },
        {
          "path": "$DESKTOP/**/*.pdf"
        },
        {
          "path": "$DOWNLOAD/**/*.pdf"
        },
        {
          "path": "$HOME/**/*.pdf"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$DOCUMENT/**/*.md"
        },
        {
          "path": "$DESKTOP/**/*.md"
        },
        {
          "path": "$DOWNLOAD/**/*.md"
        }
      ]
    }
  ]
}